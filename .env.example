# AzubiMatch – Vorlage fuer Umgebungsvariablen
# Kopieren nach .env und Werte anpassen.

# Express API
PORT=3001
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:3001

# PostgreSQL
AZUBIMATCH_DB_HOST=127.0.0.1
AZUBIMATCH_DB_PORT=5432
AZUBIMATCH_DB_NAME=azubimatch
AZUBIMATCH_DB_USER=azubimatch_app
AZUBIMATCH_DB_PASSWORD=change-me
AZUBIMATCH_DB_SCHEMA=public
AZUBIMATCH_DB_SSL=false

# JWT
AZUBIMATCH_JWT_SECRET=change-me-use-a-long-random-secret

# PHP-Backend (pgsql oder mysql)
# AZUBIMATCH_DB_DRIVER=pgsql

# ─── Produktions-Variablen (Railway + Vercel) ──────────────────────────
#
# Railway (Express API):
#   PORT            wird automatisch von Railway gesetzt – nicht setzen
#   AZUBIMATCH_DB_* werden von Railway PostgreSQL-Plugin automatisch befuellt
#                   (oder manuell als DATABASE_URL fuer pg-connection-string)
#   AZUBIMATCH_JWT_SECRET  langer Zufallsstring, im Railway Dashboard setzen
#   ALLOWED_ORIGIN  URL des Vercel-Frontends, z. B. https://azubimatch.vercel.app
#   RAILWAY_ENVIRONMENT  wird von Railway automatisch gesetzt (Erkennung fuer listen-Host)
#
# Vercel (Next.js Frontend):
#   NEXT_PUBLIC_API_BASE_URL  Railway-API-URL, z. B. https://azubimatch-api.up.railway.app
#
# Schritte:
#   1. Railway-Projekt anlegen → New Project → Deploy from GitHub → dieses Repo
#   2. Railway PostgreSQL-Plugin hinzufuegen → DB-Variablen werden automatisch gesetzt
#   3. AZUBIMATCH_JWT_SECRET und ALLOWED_ORIGIN im Railway Dashboard eintragen
#   4. Vercel-Projekt anlegen → Import Git Repository → dieses Repo
#   5. NEXT_PUBLIC_API_BASE_URL in Vercel-Umgebungsvariablen auf Railway-URL setzen

